async function deployCommandsToGuild(guildId) {
  await rest.put(Routes.applicationGuildCommands(client.user.id, guildId), { body: slashCommands });
}

async function deployCommandsToAllGuilds({ delayMs = 1200 } = {}) {
  for (const [gid] of client.guilds.cache) {
    try {
      await deployCommandsToGuild(gid);
    } catch (e) {
      console.error("Deploy failed for guild", gid, e?.message ?? e);
    }
    if (delayMs) await new Promise(r => setTimeout(r, delayMs));
  }
}

