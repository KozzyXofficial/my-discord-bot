    description: `${user}
${url}`,
    showAuthor: true,
    showFooter: false,
  }).setImage(url);

  return safeRespond(i, { embeds: [embed] });
}
async function handleBanner(i) {
  const user = i.options?.getUser?.("user") || i.user;

  const fetched = await client.users.fetch(user.id, { force: true }).catch(() => null);
  const bannerUrl = fetched?.bannerURL?.({ size: 1024, dynamic: true }) || null;

  if (!bannerUrl) {
